# Frontend Environment Configuration
# Copy this file to .env.local and adjust values for your environment

# API Base URL
# Default: http://localhost:8000 (backend running on default port)
# For production: https://api.nano-marketplace.de
VITE_API_BASE_URL=http://localhost:8000

# API Request Timeout (milliseconds)
# Default: 30000 (30 seconds)
# Increase for slow networks or large file uploads
VITE_API_REQUEST_TIMEOUT=30000

# Development Server Configuration
# The host where the frontend dev server will listen
# Default: localhost
VITE_DEV_SERVER_HOST=localhost
