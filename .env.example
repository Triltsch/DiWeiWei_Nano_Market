# Environment Configuration for DiWeiWei Nano-Marktplatz
# Copy this file to .env and update values for your environment

# Application Settings
APP_NAME="DiWeiWei Nano-Marktplatz"
APP_VERSION="0.1.0"
DEBUG=False
ENV="development"

# Database Configuration
# Choose ONE of the following based on your setup:

# 1. Development (default local PostgreSQL on port 5432)
# DATABASE_URL="postgresql://user:password@localhost:5432/diwei_nano_market"

# 2. Docker Compose (PostgreSQL on port 5433, for integration testing)
# TEST_DB_URL="postgresql+asyncpg://testuser:testpassword@localhost:5433/diweiwei_test"

# 3. Production (set DATABASE_URL with your production database)
# DATABASE_URL="postgresql://user:password@your-prod-host:5432/diweiwei_production"

# If neither DATABASE_URL nor TEST_DB_URL is set, the app will use:
# - SQLite for ENV=test (unit tests)
# - Default PostgreSQL localhost:5432 for other environments

# Redis Configuration
# Connection URL for Redis (optional, if not set falls back to REDIS_HOST:REDIS_PORT)
# For Docker Compose (or local Redis on default port): redis://localhost:6379/0
REDIS_URL="redis://localhost:6379/0"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0

# Docker Compose Service Configuration (Story 7.2 / 7.3)
# Used by docker-compose.yml for PostgreSQL + MinIO provisioning.
POSTGRES_USER="diwei_user"
POSTGRES_PASSWORD="diwei_password"
POSTGRES_DB="diwei_nano_market"
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin123"
MINIO_BUCKET_NAME="nanos"

# Meilisearch Configuration
# Required: Master key for API authentication (min 16 bytes for production)
# Change 'diweiwei-dev-master-key-32-bytes-secure' to a strong random key for production
MEILI_MASTER_KEY="diweiwei-dev-master-key-32-bytes-secure"

# JWT Configuration
# Set a strong, unique secret in production
SECRET_KEY="dev-unsafe-change-me"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Verification
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# Account Security
MAX_LOGIN_ATTEMPTS=3
ACCOUNT_LOCKOUT_DURATION_MINUTES=60

# Password Policy
MIN_PASSWORD_LENGTH=8
REQUIRE_SPECIAL_CHAR=true
REQUIRE_DIGIT=true
REQUIRE_UPPERCASE=true

# Session Settings
SESSION_TIMEOUT_MINUTES=30
