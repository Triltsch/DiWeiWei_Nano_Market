{
  "id": null,
  "uid": "feedback-flows",
  "title": "Feedback Flows",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["feedback", "observability", "sprint-6"],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Feedback Request Rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (feedback_type, operation) (rate(feedback_requests_total[5m]))",
          "legendFormat": "{{feedback_type}} {{operation}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Feedback Server Error Rate (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (sum by (feedback_type, operation) (rate(feedback_requests_total{outcome=\"server_error\"}[5m])) / clamp_min(sum by (feedback_type, operation) (rate(feedback_requests_total[5m])), 0.001))",
          "legendFormat": "{{feedback_type}} {{operation}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Feedback P95 Latency (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, feedback_type, operation) (rate(feedback_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{feedback_type}} {{operation}}"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Moderation Decisions (last hour)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (feedback_type, decision) (increase(feedback_moderation_decisions_total[1h]))",
          "legendFormat": "{{feedback_type}} {{decision}}"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 }
    }
  ]
}